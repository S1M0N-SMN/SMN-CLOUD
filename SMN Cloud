class MathAgent:
    def process(self, query, user_id, file_memory):
        try:
            expr = query.replace('×', '*').replace('÷', '/').replace('^', '**')
            expr = expr.replace(' ', '')
            if not any(op in expr for op in ['+', '-', '*', '/', '**']):
                return None
            
            result = eval(expr, {"__builtins__": {}}, {})
            if isinstance(result, float):
                if result.is_integer():
                    result = int(result)
                else:
                    result = round(result, 4)
            
            answer = f"{expr} = {result}"
            file_memory.update_stats(user_id, "dictionary_hits")
            return {"answer": answer, "confidence": 1.0, "agent": "math"}
        except:
            return None

class ChemistryAgent:
    def __init__(self):
        self.atomic_masses = {
            'H': 1.008, 'He': 4.0026, 'Li': 6.94, 'Be': 9.0122, 'B': 10.81,
            'C': 12.011, 'N': 14.007, 'O': 15.999, 'F': 18.998, 'Ne': 20.18,
            'Na': 22.99, 'Mg': 24.305, 'Al': 26.982, 'Si': 28.086, 'P': 30.974,
            'S': 32.06, 'Cl': 35.45, 'Ar': 39.95, 'K': 39.098, 'Ca': 40.078,
            'Fe': 55.845, 'Cu': 63.546, 'Zn': 65.38, 'Ag': 107.87, 'Au': 196.97,
        }
    
    def parse_formula(self, formula):
        elements = {}
        pattern = r'([A-Z][a-z]?)(\d*)'
        matches = re.findall(pattern, formula)
        for element, count in matches:
            count = int(count) if count else 1
            elements[element] = elements.get(element, 0) + count
        return elements
    
    def process(self, query, user_id, file_memory):
        formula_match = re.search(r'[A-Z][a-z]?\d*[A-Z]?[a-z]?\d*', query)
        if not formula_match:
            return None
        
        formula = formula_match.group()
        if not any(c.isupper() for c in formula):
            return None
        
        try:
            elements = self.parse_formula(formula)
            total = 0
            for element, count in elements.items():
                mass = self.atomic_masses.get(element, 0)
                total += mass * count
            
            answer = f"Молекулярная масса {formula} = {total:.3f} г/моль"
            file_memory.update_stats(user_id, "dictionary_hits")
            return {"answer": answer, "confidence": 1.0, "agent": "chemistry"}
        except:
            return None

class DictionaryAgent:
    def process(self, query, user_id, file_memory):
        words = re.findall(r'[а-яА-Яa-zA-Z]{3,}', query.lower())
        stop_words = {'привет', 'как', 'дела', 'спасибо', 'пока', 'кто', 'ты', 
                     'что', 'умеешь', 'сколько', 'слов', 'знаешь'}
        
        for word in words:
            if word in stop_words:
                continue
            
            word_data = file_memory.get_word(user_id, word)
            if word_data:
                meaning = word_data.get('meaning', '')
                mastery = word_data.get('mastery', 1)
                
                mastery_stars = "⭐" * min(mastery, 5) + "☆" * (5 - min(mastery, 5))
                answer = f"📖 '{word}' — {meaning} {mastery_stars}"
                file_memory.update_stats(user_id, "dictionary_hits")
                return {"answer": answer, "confidence": 0.9, "agent": "dictionary"}
        
        return None

class WikipediaAgent:
    def __init__(self):
        self.available = WIKIPEDIA_AVAILABLE
        if self.available:
            import wikipediaapi
            self.wiki = wikipediaapi.Wikipedia(language='ru', user_agent='SMN-Cloud/19.0')
            print("✅ Wikipedia агент готов")
    
    def extract_topic(self, query):
        words = re.findall(r'[а-яА-Яa-zA-Z]{4,}', query.lower())
        stop = {'что', 'такое', 'кто', 'как', 'почему', 'зачем', 'где', 'когда'}
        for w in words:
            if w not in stop:
                return w
        return None
    
    def process(self, query, user_id, file_memory):
        if not self.available:
            return None
        
        topic = self.extract_topic(query)
        if not topic:
            return None
        
        print(f"📖 Wikipedia: '{topic}'...")
        
        try:
            page = self.wiki.page(topic)
            if not page.exists():
                return None
            
            text = page.summary[:500]
            if text:
                file_memory.save_knowledge(user_id, topic, text)
                file_memory.update_stats(user_id, "wikipedia_hits")
                answer = f"📚 {topic}: {text}..."
                return {"answer": answer, "confidence": 0.8, "agent": "wikipedia"}
        except Exception as e:
            print(f"⚠️ Wikipedia ошибка: {e}")
        
        return None

class GeminiAgent:
    def __init__(self, gemini_api):
        self.gemini = gemini_api
    
    def process(self, query, user_id, file_memory):
        if not self.gemini.available:
            return None
        
        file_memory.update_stats(user_id, "gemini_requests")
        
        result = self.gemini.ask_structured(query, user_id, file_memory)
        if result and result.get("answer"):
            if result.get("needs_learning") and result.get("suggested_words"):
                for word in result.get("suggested_words", [])[:3]:
                    file_memory.save_word(user_id, word, "нужно выучить", "gemini")
            
            return {
                "answer": result["answer"],
                "confidence": result.get("confidence", 0.7),
                "agent": "gemini"
            }
        
        return None

