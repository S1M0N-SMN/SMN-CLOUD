class AutoSaver:
    def __init__(self, smn_instance, save_interval_minutes=20):
        self.smn = smn_instance
        self.save_interval = save_interval_minutes * 60
        self.last_save = time.time()
        self.running = True
        self.thread = threading.Thread(target=self._auto_save_loop, daemon=True)
        self.thread.start()
        print(f"💾 Автосохранение включено (каждые {save_interval_minutes} минут)")
    
    def _auto_save_loop(self):
        while self.running:
            time.sleep(60)
            if time.time() - self.last_save >= self.save_interval:
                self.save_all()
                self.last_save = time.time()
    
    def save_all(self):
        print(f"\n💾 [АВТОСОХРАНЕНИЕ] {datetime.now().strftime('%H:%M:%S')}")
        
        # Сохраняем чекпоинт
        checkpoint = {
            'timestamp': datetime.now().isoformat(),
            'words_count': len(self.smn.file_memory.get_all_words("default", 9999)),
            'version': 'SMN_Cloud_v19.0'
        }
        
        with open(f"{CHECKPOINT_PATH}/last_checkpoint.json", 'w', encoding='utf-8') as f:
            json.dump(checkpoint, f, ensure_ascii=False, indent=2)
        
        print(f"✅ Чекпоинт сохранён: {checkpoint['words_count']} слов")
    
    def stop(self):
        self.running = False

