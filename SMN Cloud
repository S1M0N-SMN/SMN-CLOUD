# ШАГ 7: ДИСПЕТЧЕР АГЕНТОВ
# ============================================
class AgentDispatcher:
    def __init__(self, file_memory, gemini_api):
        self.file_memory = file_memory
        self.gemini = gemini_api
        
        self.agents = [
            MathAgent(),
            ChemistryAgent(),
            DictionaryAgent(),
            WikipediaAgent(),
            GeminiAgent(gemini_api),
        ]
    
    def dispatch(self, query, user_id):
        for agent in self.agents:
            result = agent.process(query, user_id, self.file_memory)
            if result:
                return result
        
        return {
            "answer": "Извините, я не смогла обработать ваш запрос.",
            "confidence": 0.0,
            "agent": "none"
        }

