class GeminiAPI:
    def __init__(self, api_key):
        self.api_key = api_key
        self.available = bool(api_key) and api_key != "ВАШ_GEMINI_API_KEY_СЮДА"
        self.model = "gemini-1.5-flash"
        self.last_request = 0
        
        if self.available:
            print("✅ Gemini API готов")
        else:
            print("⚠️ Gemini API не доступен")
    
    def _rate_limit(self):
        now = time.time()
        if now - self.last_request < 1:
            time.sleep(1)
        self.last_request = now
    
    def get_system_prompt(self, user_id, file_memory):
        user = file_memory.get_or_create_user(user_id)
        user_name = user.get("name", "пользователь")
        words = file_memory.get_all_words(user_id, 9999)
        words_count = len(words)
        current_time = datetime.now().strftime("%d.%m.%Y %H:%M:%S")
        
        return f"""Ты - SMN Cloud (Self-learning Neural Network) v19.0.

ТВОЯ ЛИЧНОСТЬ:
- Ты работаешь в облаке и обслуживаешь пользователя {user_name}
- Его словарь содержит {words_count} слов
- Ты умеешь учиться новым словам и запоминать контекст
- Ты помнишь историю диалога (до 20 сообщений)

ТЕКУЩЕЕ ВРЕМЯ: {current_time}

ВАЖНЫЕ ПРАВИЛА:
1. Не выдумывай несуществующие факты
2. Если не знаешь ответа - скажи "Я ещё не выучила это, научи меня!"
3. Отвечай на русском языке
4. Будь дружелюбной и полезной
"""
    
    def ask_structured(self, query, user_id, file_memory, use_context=True):
        if not self.available:
            return None
        
        self._rate_limit()
        
        system_prompt = self.get_system_prompt(user_id, file_memory)
        context = file_memory.get_context_string(user_id) if use_context else ""
        
        prompt = f"""{system_prompt}

{context}

Вопрос пользователя: {query}

ОТВЕТЬ ТОЛЬКО В ФОРМАТЕ JSON, без лишнего текста. Используй эту структуру:
{{
    "answer": "твой ответ здесь",
    "confidence": 0.0-1.0,
    "needs_learning": false,
    "suggested_words": []
}}
"""
        
        try:
            url = f"https://generativelanguage.googleapis.com/v1beta/models/{self.model}:generateContent?key={self.api_key}"
            payload = {
                "contents": [{"parts": [{"text": prompt}]}],
                "generationConfig": {"temperature": 0.5, "maxOutputTokens": 500}
            }
            response = requests.post(url, json=payload, timeout=20)
            
            if response.status_code == 200:
                data = response.json()
                if 'candidates' in data and data['candidates']:
                    text = data['candidates'][0]['content']['parts'][0]['text']
                    json_match = re.search(r'\{.*\}', text, re.DOTALL)
                    if json_match:
                        return json.loads(json_match.group())
            return None
        except Exception as e:
            print(f"⚠️ Gemini ошибка: {e}")
            return None

