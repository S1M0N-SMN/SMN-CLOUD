    def process_query(self, user_id, query, user_name=None):
        user = self.file_memory.get_or_create_user(user_id, user_name)
        user_name = user.get('name', 'пользователь')
        
        # Проверяем простые фразы
        query_lower = query.lower()
        for key, templates in self.phrases.items():
            if key in query_lower:
                words_count = len(self.file_memory.get_all_words(user_id, 9999))
                template = random.choice(templates)
                response = template.replace('{user_name}', user_name).replace('{words}', str(words_count))
                self.file_memory.save_conversation(user_id, query, response, "phrase")
                return {
                    "response": response,
                    "agent": "phrase",
                    "user_name": user_name
                }
        
        # Отправляем агентам
        result = self.dispatcher.dispatch(query, user_id)
        response = result.get("answer", "Не могу ответить")
        agent = result.get("agent", "unknown")
        
        self.file_memory.save_conversation(user_id, query, response, agent)
        
        return {
            "response": response,
            "agent": agent,
            "confidence": result.get("confidence", 0.5),
            "user_name": user_name
        }
    
    def get_stats(self, user_id):
        user = self.file_memory.get_or_create_user(user_id)
        words = self.file_memory.get_all_words(user_id, 9999)
        conversations = self.file_memory.get_history(user_id, 9999)
        
        return {
            "user_id": user_id,
            "user_name": user.get("name"),
            "words_count": len(words),
            "total_queries": user.get("stats", {}).get("total_queries", 0),
            "dictionary_hits": user.get("stats", {}).get("dictionary_hits", 0),
            "wikipedia_hits": user.get("stats", {}).get("wikipedia_hits", 0),
            "gemini_requests": user.get("stats", {}).get("gemini_requests", 0),
            "conversations": len(conversations),
            "created_at": user.get("created_at")
        }
    
    def get_words(self, user_id, limit=50):
        return self.file_memory.get_all_words(user_id, limit)
    
    def learn_word(self, user_id, word, meaning):
        self.file_memory.save_word(user_id, word, meaning, "user")
        return {"status": "learned", "word": word, "meaning": meaning}
    
    def save_feedback(self, user_id, query, response, rating):
        self.file_memory.save_feedback(user_id, query, response, rating)
        return {"status": "saved", "rating": rating}
    
    def console_chat(self):
        """Консольный чат для Colab"""
        user_id = "colab_user"
        user_name = input("Как вас зовут? ") or "пользователь"
        
        print(f"\n👋 Привет, {user_name}! Я SMN Cloud. Чем могу помочь?")
        print("(для выхода напишите 'exit' или 'quit')\n")
        
        while True:
            try:
                query = input("💬 Вы: ").strip()
                
                if query.lower() in ['exit', 'quit', 'выход']:
                    print("👋 До свидания! Данные сохранены.")
                    break
                
                if query:
                    result = self.process_query(user_id, query, user_name)
                    print(f"🤖 SMN: {result['response']}\n")
                    
            except KeyboardInterrupt:
                print("\n👋 До свидания!")
                break
            except Exception as e:
                print(f"❌ Ошибка: {e}")

