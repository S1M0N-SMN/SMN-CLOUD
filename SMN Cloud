class FileMemory:
    def __init__(self, storage_path):
        self.storage_path = storage_path
        print(f"📁 Хранилище: {storage_path}")
    
    def _get_file_path(self, user_id, collection):
        return os.path.join(self.storage_path, f"{user_id}_{collection}.json")
    
    def _load_json(self, file_path):
        if os.path.exists(file_path):
            try:
                with open(file_path, 'r', encoding='utf-8') as f:
                    return json.load(f)
            except:
                return [] if "conversations" in file_path else {}
        return [] if "conversations" in file_path else {}
    
    def _save_json(self, file_path, data):
        with open(file_path, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
    
    def get_or_create_user(self, user_id, user_name=None):
        file_path = self._get_file_path(user_id, "user")
        user = self._load_json(file_path)
        
        if not user:
            user = {
                "user_id": user_id,
                "name": user_name or f"User_{user_id[:8]}",
                "created_at": datetime.now().isoformat(),
                "stats": {
                    "total_queries": 0,
                    "dictionary_hits": 0,
                    "wikipedia_hits": 0,
                    "gemini_requests": 0,
                    "self_learned": 0
                }
            }
            self._save_json(file_path, user)
            print(f"👤 Новый пользователь: {user['name']}")
        
        return user
    
    def update_stats(self, user_id, stat_name):
        file_path = self._get_file_path(user_id, "user")
        user = self._load_json(file_path)
        if user:
            user["stats"][stat_name] = user["stats"].get(stat_name, 0) + 1
            user["stats"]["total_queries"] = user["stats"].get("total_queries", 0) + 1
            self._save_json(file_path, user)
    
    def save_conversation(self, user_id, query, response, agent_used):
        file_path = self._get_file_path(user_id, "conversations")
        conversations = self._load_json(file_path)
        conversations.append({
            "query": query,
            "response": response,
            "agent_used": agent_used,
            "timestamp": datetime.now().isoformat()
        })
        if len(conversations) > 100:
            conversations = conversations[-100:]
        self._save_json(file_path, conversations)
    
    def get_history(self, user_id, limit=20):
        file_path = self._get_file_path(user_id, "conversations")
        conversations = self._load_json(file_path)
        return conversations[-limit:] if conversations else []
    
    def get_context_string(self, user_id):
        history = self.get_history(user_id, 10)
        if not history:
            return ""
        
        context = "Предыдущий диалог:\n"
        for msg in history:
            context += f"Пользователь: {msg['query']}\n"
            context += f"SMN: {msg['response']}\n"
        return context
    
    def save_word(self, user_id, word, meaning, source="user"):
        file_path = self._get_file_path(user_id, "vocabulary")
        vocabulary = self._load_json(file_path)
        vocabulary[word.lower()] = {
            "meaning": meaning,
            "source": source,
            "mastery": 1,
            "updated_at": datetime.now().isoformat()
        }
        self._save_json(file_path, vocabulary)
    
    def get_word(self, user_id, word):
        file_path = self._get_file_path(user_id, "vocabulary")
        vocabulary = self._load_json(file_path)
        return vocabulary.get(word.lower())
    
    def get_all_words(self, user_id, limit=100):
        file_path = self._get_file_path(user_id, "vocabulary")
        vocabulary = self._load_json(file_path)
        items = list(vocabulary.items())
        return [{"word": w, "meaning": d.get("meaning"), "mastery": d.get("mastery", 1)} 
                for w, d in items[:limit]]
    
    def increase_mastery(self, user_id, word):
        file_path = self._get_file_path(user_id, "vocabulary")
        vocabulary = self._load_json(file_path)
        if word.lower() in vocabulary:
            vocabulary[word.lower()]["mastery"] = vocabulary[word.lower()].get("mastery", 1) + 1
            self._save_json(file_path, vocabulary)
    
    def save_knowledge(self, user_id, topic, info):
        file_path = self._get_file_path(user_id, "knowledge")
        knowledge = self._load_json(file_path)
        knowledge[topic.lower()] = {
            "info": info,
            "updated_at": datetime.now().isoformat()
        }
        self._save_json(file_path, knowledge)
    
    def get_knowledge(self, user_id, topic):
        file_path = self._get_file_path(user_id, "knowledge")
        knowledge = self._load_json(file_path)
        return knowledge.get(topic.lower())
    
    def save_feedback(self, user_id, query, response, rating):
        file_path = self._get_file_path(user_id, "feedback")
        feedbacks = self._load_json(file_path)
        feedbacks.append({
            "query": query,
            "response": response,
            "rating": rating,
            "timestamp": datetime.now().isoformat()
        })
        self._save_json(file_path, feedbacks[-100:])
        
        if rating >= 4:
            words = re.findall(r'[а-яА-Яa-zA-Z]{3,}', query.lower())
            for word in words[:3]:
                self.increase_mastery(user_id, word)

